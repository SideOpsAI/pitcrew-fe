# Netlify Forms target URL
# Local dev: set this to your deployed Netlify site URL
NETLIFY_FORMS_URL=https://your-site-name.netlify.app

# Optional local mode: when true, /api/contact returns success without posting to Netlify
MOCK_FORM_DELIVERY=false

# Local CAPTCHA signing key (booking CAPTCHA)
CAPTCHA_SECRET=change-me-with-a-long-random-string
# Optional alias used in some deploy environments
BOOKING_CAPTCHA_SECRET=change-me-with-a-long-random-string
